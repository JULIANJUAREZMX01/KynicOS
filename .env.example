# ============================================================
# KynicOS — Environment Variables
# Copia este archivo a .env y llena los valores
# ============================================================

# ── Persona activa ───────────────────────────────────────────
# Opciones: leo (concierge turistas) | nexus (admin Julián) | mueve (transporte)
PERSONA=leo

# ── Hotel Config (para modo LEO) ─────────────────────────────
HOTEL_NAME=Resort Playa Mujeres
HOTEL_LOCATION=Playa Mujeres, Cancún
HOTEL_CURRENCY=USD
HOTEL_TIMEZONE=America/Mexico_City

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
# Tu propio chat_id (admin/Julián)
TELEGRAM_USER_ID=your_telegram_user_id
# Chat ID del técnico de mantenimiento (para escalar tickets HVAC)
TECH_TELEGRAM_CHAT_ID=your_tech_chat_id

# ── LLM Providers ───────────────────────────────────────────
# Groq (primario — gratis, muy rápido)
GROQ_API_KEY=gsk_your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic Claude (fallback)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key
ANTHROPIC_MODEL=claude-opus-4-5

# OpenAI (opcional, para voz con Whisper)
OPENAI_API_KEY=sk-your_openai_key

# ── WhatsApp (Twilio) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=+14155238886
# Tu número de WhatsApp (para alertas proactivas)
TWILIO_WHATSAPP_TO=+521XXXXXXXXXX

# ── Stripe (Fase 2 — pagos) ──────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxx
STRIPE_HOTEL_ACCOUNT_ID=acct_hotel_xxxxx
STRIPE_NEXUS_ACCOUNT_ID=acct_nexus_xxxxx
STRIPE_COMMISSION_PERCENTAGE=5

# ── Base de Datos (Fase 2) ───────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/kynicos_db
REDIS_URL=redis://localhost:6379

# ── AWS S3 (backups opcionales) ──────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# ── App ──────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
PORT=8000
HOST=0.0.0.0
